# Local Docker Postgres (default for development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nasa_fan"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Frontend origin for CORS (nasa-fan runs on 3000)
FRONTEND_URL="http://localhost:3000"

