generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mission {
  id          String    @id @default(cuid())
  name        String
  agency      String    @default("NASA")
  launchDate  DateTime? @map("launch_date")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("missions")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  searchFavorites SearchFavorite[]

  @@map("users")
}

model SearchFavorite {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  nasaId       String   @map("nasa_id")
  title        String
  description  String
  dateCreated  String   @map("date_created")
  thumbnailUrl String   @map("thumbnail_url")
  imageUrl     String   @map("image_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nasaId])
  @@map("search_favorites")
}